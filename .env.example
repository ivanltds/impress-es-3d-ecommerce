# ===========================================
# 3DPrint Store - Environment Variables
# ===========================================
# Copie este arquivo para .env.local e preencha

# --- Database (Supabase) ---
DATABASE_URL="postgresql://postgres:password@localhost:5432/3dprint-store"
DIRECT_URL="postgresql://postgres:password@localhost:5432/3dprint-store"

# --- Auth (NextAuth.js) ---
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- Pagamentos (Stripe) ---
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# --- Pagamentos (Mercado Pago - Brasil) ---
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_PUBLIC_KEY=""

# --- Storage (Vercel Blob) ---
BLOB_READ_WRITE_TOKEN=""

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="3DPrint Store"
