# ===========================================
# Impressão 3D Personalizada — Environment Variables
# ===========================================
# Copie este arquivo para .env e preencha os valores reais

# --- Database (Supabase PostgreSQL) ---
DATABASE_URL="postgresql://postgres:password@host:5432/dbname"
DIRECT_URL="postgresql://postgres:password@host:5432/dbname"

# --- Auth (NextAuth.js v5) ---
AUTH_SECRET="generate-with: openssl rand -base64 32"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Impressão 3D Personalizada"

# --- Pagamentos (Stripe — M04) ---
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# --- Pagamentos (MercadoPago — M04) ---
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_PUBLIC_KEY=""

# --- Storage (Vercel Blob — M02) ---
BLOB_READ_WRITE_TOKEN=""

# --- Frete (Correios API — M03) ---
CORREIOS_API_KEY=""
