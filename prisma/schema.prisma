generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── F3: Banco de Dados (cenários 3.1, 3.2, 3.3) ───
// ─── F4: Autenticação (cenários 4.1 a 4.8) ───

model User {
  id                  String    @id @default(cuid())
  name                String?
  email               String?   @unique
  emailVerified       DateTime?
  passwordHash        String?   // hashed password (NextAuth handles via adapter)
  image               String?
  phone               String?
  document            String?   // CPF sem pontuação
  role                String    @default("customer") // admin, operator, partner, customer
  marketingConsent    Boolean   @default(false)
  preferredTheme      String?   // theme_key
  preferredCollection String?   // collection slug
  status              String    @default("active") // active, inactive, banned

  // ─── F4.8: Sessão persistente ───
  accounts            Account[]
  sessions            Session[]

  // ─── Relacionamentos futuros (M02+) ───
  themePreferences    ThemePreference[]
  addresses           Address[]
  orders              Order[]
  cart                Cart?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

// ─── NextAuth.js models ───

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── F5: Tema (cenários 5.1 a 5.8) ───

model ThemePreference {
  id        String   @id @default(cuid())
  userId    String?  // nullable: guest users use session_id
  sessionId String?  // for non-logged-in users
  themeKey  String   // core, gamer, anime, home, gifts, auto
  source    String   @default("manual") // manual, suggested, default
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  lastUpdated DateTime @updatedAt

  @@index([userId])
  @@index([sessionId])
}

// ─── M02: Catalog ───

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  products    Product[]
}

model Product {
  id                     String   @id @default(cuid())
  name                   String
  slug                   String   @unique
  shortDescription       String
  longDescription        String?
  basePrice              Float
  comparePrice           Float?
  categoryId             String?
  collectionId           String?
  productType            String   @default("simple")
  isCustomizable         Boolean  @default(false)
  customizationLevel     String   @default("none")
  estimatedProductionTime Int?
  material               String?
  isFeatured             Boolean  @default(false)
  images                 String[]
  status                 String   @default("published")
  seoTitle               String?
  seoDescription         String?
  legalNotes             String?
  customizationSchema    Json?    // array de CustomizationField — define o formulário de personalização
  category               Category? @relation(fields: [categoryId], references: [id])
  universes              ProductUniverse[]  // ← M05: relação M:N com universos
  promoBanners           PromoBannerProduct[]  // ← M06: relação com faixa promocional
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

// ─── M04: Leads ───

model Lead {
  id                 String   @id @default(cuid())
  name               String
  email              String   @default("")
  phone              String   @default("")
  source             String   @default("website")
  interestCollection String   @default("")
  message            String   @default("")
  status             String   @default("novo")
  notes              String?
  orderId            String?
  paymentLink        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// ─── Outros modelos ───

model Address {
  id            String  @id @default(cuid())
  userId        String
  label         String  // Casa, Trabalho
  recipientName String
  cep           String
  street        String
  number        String
  complement    String?
  district      String
  city          String
  state         String
  country       String  @default("Brasil")
  isDefault     Boolean @default(false)
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Cart {
  id        String     @id @default(cuid())
  userId    String?    @unique
  sessionId String
  status    String     @default("active") // active, converted, abandoned
  user      User?      @relation(fields: [userId], references: [id])
  items     CartItem[]
}

model CartItem {
  id                   String  @id @default(cuid())
  cartId               String
  productId            String
  variantId            String?
  qty                  Int
  unitPrice            Float
  customizationPayload String? // JSON
  lineTotal            Float
  cart                 Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
}

model Order {
  id               String    @id @default(cuid())
  userId           String?
  orderNumber      String    @unique
  status           String    @default("created")
  paymentStatus    String    @default("pending")
  fulfillmentStatus String   @default("unfulfilled")
  subtotal         Float
  shippingCost     Float     @default(0)
  discount         Float     @default(0)
  total            Float
  currency         String    @default("BRL")
  sourceChannel    String?
  notes            String?
  themeSnapshot    String?
  cep              String?  // CEP for shipping label generation
  shippingStreet   String?
  shippingNumber   String?
  shippingDistrict String?
  shippingCity     String?
  shippingState    String?
  trackingCode     String?  // código de rastreio Melhor Envio
  user             User?     @relation(fields: [userId], references: [id])
  items            OrderItem[]
  createdAt        DateTime  @default(now())
}

model OrderItem {
  id                     String   @id @default(cuid())
  orderId                String
  productId              String
  productNameSnapshot    String
  skuSnapshot            String
  qty                    Int
  unitPrice              Float
  customizationSnapshot  String?  // JSON — valores preenchidos pelo cliente (congelados)
  customizationPrice     Float    @default(0) // acréscimos de personalização
  productionStatus       String   @default("pending")
  productionNotes        String?
  order                  Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// ─── StoreSettings: configurações gerais da loja (singleton id="singleton") ───
model StoreSettings {
  id             String   @id @default("singleton")
  whatsappPhone  String   @default("")  // ex: "5511999999999" (com DDI, sem +)
  updatedAt      DateTime @updatedAt
}

// ─── StoreAddress: endereços de origem da loja para etiquetas ───
model StoreAddress {
  id           String   @id @default(cuid())
  name         String   // ex: "Osasco SP", "Filial RJ"
  phone        String   @default("")  // ex: "11999999999"
  email        String   @default("")  // ex: "loja@email.com"
  document     String   @default("")  // CPF ou CNPJ sem pontuação
  street       String
  number       String
  complement   String?
  neighborhood String   @default("")
  city         String
  state        String   // UF ex: "SP"
  cep          String   // formatado: "06110-000"
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── M05: Universos de Tema ───────────────────────────────────────────────────

model Universe {
  id           String            @id @default(cuid())
  slug         String            @unique
  name         String
  comingSoon   Boolean           @default(false)
  sortOrder    Int               @default(0)

  // FF08: campos editáveis via admin
  cardImageUrl String?  // URL pública Vercel Blob — null = fallback decorativo no pill
  heroImageUrl String?  // URL pública Vercel Blob — null = fallback grid+glow no painel
  tagline      String?  // quando null, usar UNIVERSE_CONFIG[slug].tagline
  bullets      String[] // 3 bullets; vazio = usar UNIVERSE_DETAILS[slug].bullets

  products     ProductUniverse[]
  testimonials Testimonial[]

  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model ProductUniverse {
  productId  String
  universeId String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  universe   Universe @relation(fields: [universeId], references: [id], onDelete: Cascade)

  @@id([productId, universeId])
  @@index([universeId])
  @@index([productId])
}

model Testimonial {
  id           String    @id @default(cuid())
  authorName   String
  authorPhoto  String?
  productPhoto String?
  text         String
  universeId   String?
  universe     Universe? @relation(fields: [universeId], references: [id], onDelete: SetNull)
  isPublished  Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  @@index([isPublished])
  @@index([universeId, isPublished])
}

// ─── M06: Feature 7 — Faixa Promocional ──────────────────────────────────────

model PromoBanner {
  id        String               @id @default(cuid())
  title     String
  subtitle  String?
  startsAt  DateTime
  endsAt    DateTime
  isActive  Boolean              @default(true)
  products  PromoBannerProduct[]
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([isActive, startsAt, endsAt])
}

model PromoBannerProduct {
  bannerId  String
  productId String
  sortOrder Int         @default(0)

  banner    PromoBanner @relation(fields: [bannerId],  references: [id], onDelete: Cascade)
  product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([bannerId, productId])
  @@index([bannerId, sortOrder])
}
